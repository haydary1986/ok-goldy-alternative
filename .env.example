# ============================================================
# Goldy — environment template
# Copy this file to .env and fill in real values.
# ============================================================

# --- HTTP server ---
GOLDY_HTTP_ADDR=0.0.0.0:8080
GOLDY_LOG_LEVEL=info
GOLDY_LOG_FORMAT=json

# --- PostgreSQL ---
GOLDY_DATABASE_URL=postgres://goldy:goldy@postgres:5432/goldy?sslmode=disable

# --- Redis (asynq job queue) ---
GOLDY_REDIS_ADDR=redis:6379
GOLDY_REDIS_PASSWORD=
GOLDY_REDIS_DB=0

# --- Google Workspace (Service Account + Domain-Wide Delegation) ---
# Path (inside the container) to the downloaded service-account JSON key
GOLDY_GOOGLE_SA_KEY_FILE=/secrets/service-account.json
# A super admin email in your Workspace domain — the service account
# impersonates this user when calling Admin SDK.
GOLDY_GOOGLE_DELEGATED_ADMIN=admin@example.com
# Your Workspace customer ID. Use "my_customer" if you only have one.
GOLDY_GOOGLE_CUSTOMER_ID=my_customer

# --- Admin SDK rate limiting ---
# Default Workspace quota = 2400 req / 100s ~= 24 rps. Stay safely under.
GOLDY_RATE_LIMIT_RPS=20
GOLDY_RATE_LIMIT_BURST=40

# --- Async worker ---
GOLDY_WORKER_CONCURRENCY=10

# --- App auth (the Goldy admin UI itself) ---
# Comma-separated list of emails allowed to log into Goldy.
GOLDY_ALLOWED_ADMINS=admin@example.com
# Random 32-byte hex string. Used to sign session cookies.
GOLDY_SESSION_SECRET=change-me-to-a-32-byte-hex-string
